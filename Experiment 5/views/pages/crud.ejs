<h1>Product Database CRUD</h1>
<h2>Sub-Experiment 5.1: Mongoose Operations</h2>

<form action="/products" method="POST" class="form-grid">
    <div class="form-group">
        <label>SKU</label>
        <input type="text" name="sku" placeholder="PROD-001" required>
    </div>
    <div class="form-group">
        <label>Name</label>
        <input type="text" name="name" placeholder="Gadget Name" required>
    </div>
    <div class="form-group">
        <label>Price</label>
        <input type="number" name="basePrice" placeholder="50.00" step="0.01" required>
    </div>
    <div class="form-group">
        <label>Category</label>
        <input type="text" name="category" placeholder="Home" required>
    </div>
    <!-- Fields for variant so create doesn't fail validation -->
    <input type="hidden" name="size" value="N/A">
    <input type="hidden" name="color" value="N/A">
    <input type="hidden" name="stock" value="0">
    
    <div class="form-group" style="justify-content: flex-end; display: flex;">
        <button type="submit" class="btn-primary">Add Product</button>
    </div>
</form>

<div class="table-wrapper">
    <table>
        <thead>
            <tr>
                <th>SKU</th>
                <th>Product Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <% products.forEach(p => { %>
                <tr>
                    <td><span class="badge"><%= p.sku %></span></td>
                    <td><strong><%= p.name %></strong></td>
                    <td><%= p.category %></td>
                    <td>$<%= p.basePrice %></td>
                    <td>
                        <form action="/products/<%= p._id %>?_method=DELETE" method="POST" style="display:inline;">
                            <button type="submit" class="delete-btn">Delete</button>
                        </form>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>
