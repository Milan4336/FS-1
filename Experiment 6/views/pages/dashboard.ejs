<div class="dashboard-grid">
    <!-- Left Panel: Balance & Transaction -->
    <div>
        <div class="balance-widget">
            <span style="font-size: 0.8rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase;">Total Balance</span>
            <div class="balance-val">$<%= user.balance.toLocaleString() %></div>
            <div style="background: rgba(16, 185, 129, 0.1); color: var(--accent); padding: 0.4rem; border-radius: 8px; font-size: 0.75rem; font-weight: 800; display: inline-block;">
                ● SAFE & SECURE
            </div>
        </div>

        <div class="glass-card" style="margin-top: 2rem;">
            <h3 style="margin-bottom: 1.5rem;">New Instant Transfer</h3>
            <form id="transfer-form">
                <div class="form-group">
                    <label>Recipient Email</label>
                    <input type="email" name="receiverEmail" placeholder="recipient@bank.com" required>
                </div>
                <div class="form-group">
                    <label>Transfer Amount ($)</label>
                    <input type="number" name="amount" placeholder="50.00" min="1" step="0.01" required>
                </div>
                <button type="submit" class="btn-primary" id="transfer-btn">Confirm Transfer</button>
            </form>
        </div>
    </div>

    <!-- Right Panel: Ledger -->
    <div class="glass-card">
        <h3 style="margin-bottom: 0.5rem;">Banking Ledger (Sub 6.3)</h3>
        <p style="color: var(--text-muted); font-size: 0.8rem; margin-bottom: 2rem;">Audit trail for ACID-compliant transactions.</p>

        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Timestamp</th>
                        <th>Party</th>
                        <th>Amount</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <% transactions.forEach(tx => { %>
                        <% 
                            const isSender = tx.sender && tx.sender._id.toString() === userId.toString();
                            const party = isSender ? (tx.receiver ? tx.receiver.name : 'Unknown') : (tx.sender ? tx.sender.name : 'Unknown');
                            const typeLabel = isSender ? '-' : '+';
                            const typeColor = isSender ? '#fb7185' : '#34d399';
                        %>
                        <tr>
                            <td><small><%= new Date(tx.createdAt).toLocaleTimeString() %></small></td>
                            <td><strong><%= party %></strong><br><small style="color:var(--text-muted)"><%= isSender ? 'Sent to' : 'Received from' %></small></td>
                            <td style="color: <%= typeColor %>; font-weight: 800;"><%= typeLabel %>$<%= tx.amount %></td>
                            <td>
                                <span class="status-badge status-<%= tx.status %>">
                                    <%= tx.status %>
                                </span>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    const tForm = document.getElementById('transfer-form');
    const tBtn = document.getElementById('transfer-btn');

    tForm.onsubmit = async (e) => {
        e.preventDefault();
        tBtn.disabled = true;
        tBtn.innerText = 'Locking Transaction...';

        const data = Object.fromEntries(new FormData(tForm));

        try {
            const res = await fetch('/api/banking/transfer', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await res.json();

            if (result.success) {
                window.location.reload();
            } else {
                alert('ACID Transaction Failed: ' + result.error);
                window.location.reload(); 
            }
        } catch (err) {
            alert('Failed to connect to Banking Core.');
        } finally {
            tBtn.disabled = false;
        }
    };
</script>
