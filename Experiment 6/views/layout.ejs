<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Experiment 6 | Banking Hub</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&family=Plus+Jakarta+Sans:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="background-blobs">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
    </div>

    <header>
        <nav>
            <div class="logo">Experiment <span>6</span></div>
            <% if (typeof user !== 'undefined' && user) { %>
                <div style="display:flex; gap: 1.5rem; align-items:center;">
                    <span style="font-weight:700; color:var(--text-muted); font-size: 0.9rem;">Hi, <%= user.name %></span>
                    <a href="/auth/logout" style="color:var(--secondary); text-decoration:none; font-weight:700; font-size: 0.85rem;">Sign Out</a>
                </div>
            <% } %>
        </nav>
    </header>

    <main class="container">
        <%- body %>
    </main>
</body>
</html>
